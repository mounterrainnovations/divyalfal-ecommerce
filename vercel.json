{
  "crons": [
    {
      "path": "/api/cron/reconcile-payments",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/cleanup-stock",
      "schedule": "0 0 * * *"
    }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "includeFiles": "node_modules/.prisma/client/**"
    },
    "app/product/**/*.tsx": {
      "includeFiles": "node_modules/.prisma/client/**"
    }
  }
}
